---
/*
  Renders a real image when `src` is provided, otherwise a warm, on-brand
  photo-ready frame (not a broken gray box). Wickie drops photos into
  /public/images via the /admin editor and sets the path per item; that
  swaps any frame for the real photo.
*/
interface Props {
  src?: string;
  alt?: string;
  label?: string;
  class?: string;
  ratio?: string; // e.g. '4/3', '1/1', '4/5'
  loading?: 'lazy' | 'eager'; // eager = above the fold (hero): load first, everything else waits
}
const { src, alt = '', label = 'Photo coming soon', class: klass = '', ratio = '4/3', loading = 'lazy' } =
  Astro.props;
---

{
  src ? (
    <img
      src={src}
      alt={alt}
      loading={loading}
      fetchpriority={loading === 'eager' ? 'high' : undefined}
      decoding="async"
      class={`h-full w-full object-cover ${klass}`}
      style={`aspect-ratio:${ratio}`}
    />
  ) : (
    <div
      class={`relative flex items-center justify-center overflow-hidden bg-primary-tint ${klass}`}
      style={`aspect-ratio:${ratio}`}
      role="img"
      aria-label={`${label} placeholder`}
    >
      {/* soft tonal wash so the frame reads as intentional, not empty */}
      <div
        class="pointer-events-none absolute inset-0 opacity-70"
        style="background:radial-gradient(120% 90% at 78% 12%, oklch(0.86 0.09 60 / 0.7), transparent 60%), radial-gradient(120% 90% at 20% 95%, oklch(0.82 0.11 40 / 0.45), transparent 55%)"
      >
      </div>
      <span class="relative flex flex-col items-center gap-2 text-primary-deep/80">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 3v7a2 2 0 0 0 2 2h0a2 2 0 0 0 2-2V3" />
          <path d="M6 12v9" />
          <path d="M17 3c-1.7 0-3 2-3 5s1.3 4 3 4 3-1 3-4-1.3-5-3-5Z" />
          <path d="M17 12v9" />
        </svg>
        <span class="font-hand text-lg leading-none">{label}</span>
      </span>
    </div>
  )
}
