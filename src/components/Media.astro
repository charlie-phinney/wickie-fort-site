---
/*
  Renders a real image when `src` is provided, otherwise a warm, on-brand
  photo-ready frame (not a broken gray box). Wickie drops photos into
  /public/images via the /admin editor and sets the path per item; that
  swaps any frame for the real photo.

  Modern formats: CI (deploy.yml) writes webp variants next to each photo
  ("<name>-800.webp", "<name>-1600.webp", widths from the real file). When
  they exist at build time this becomes a <picture> with a srcset; when they
  don't (a photo uploaded moments ago), it's the plain <img> until the next
  deploy's housekeeping commit catches up. Never breaks either way.
*/
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  src?: string;
  alt?: string;
  label?: string;
  class?: string;
  ratio?: string; // e.g. '4/3', '1/1', '4/5'
  loading?: 'lazy' | 'eager'; // eager = above the fold (hero): load first, everything else waits
  sizes?: string; // how wide this image renders, for srcset selection
}
const {
  src,
  alt = '',
  label = 'Photo coming soon',
  class: klass = '',
  ratio = '4/3',
  loading = 'lazy',
  sizes = '(min-width: 768px) 50vw, 100vw',
} = Astro.props;

// Find CI-generated webp variants for this photo: public/images/foo-<W>.webp
let srcset = '';
if (src && /^\/images\/[^/]+\.(jpe?g|png)$/i.test(src)) {
  const file = path.join('public', src);
  const dir = path.dirname(file);
  const base = path.basename(file).replace(/\.[^.]+$/, '');
  try {
    srcset = fs
      .readdirSync(dir)
      .map((f) => {
        const m = f.match(/^(.+)-(\d+)\.webp$/);
        return m && m[1] === base ? { f, w: parseInt(m[2], 10) } : null;
      })
      .filter((v): v is { f: string; w: number } => !!v)
      .sort((a, b) => a.w - b.w)
      .map((v) => `/images/${v.f} ${v.w}w`)
      .join(', ');
  } catch {
    /* directory missing — plain <img> below */
  }
}
---

{
  src ? (
    srcset ? (
      <picture>
        <source type="image/webp" srcset={srcset} sizes={sizes} />
        <img
          src={src}
          alt={alt}
          loading={loading}
          fetchpriority={loading === 'eager' ? 'high' : undefined}
          decoding="async"
          class={`h-full w-full object-cover ${klass}`}
          style={`aspect-ratio:${ratio}`}
        />
      </picture>
    ) : (
      <img
        src={src}
        alt={alt}
        loading={loading}
        fetchpriority={loading === 'eager' ? 'high' : undefined}
        decoding="async"
        class={`h-full w-full object-cover ${klass}`}
        style={`aspect-ratio:${ratio}`}
      />
    )
  ) : (
    <div
      class={`relative flex items-center justify-center overflow-hidden bg-primary-tint ${klass}`}
      style={`aspect-ratio:${ratio}`}
      role="img"
      aria-label={`${label} placeholder`}
    >
      {/* soft tonal wash so the frame reads as intentional, not empty */}
      <div
        class="pointer-events-none absolute inset-0 opacity-70"
        style="background:radial-gradient(120% 90% at 78% 12%, oklch(0.86 0.09 60 / 0.7), transparent 60%), radial-gradient(120% 90% at 20% 95%, oklch(0.82 0.11 40 / 0.45), transparent 55%)"
      >
      </div>
      <span class="relative flex flex-col items-center gap-2 text-primary-deep/80">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 3v7a2 2 0 0 0 2 2h0a2 2 0 0 0 2-2V3" />
          <path d="M6 12v9" />
          <path d="M17 3c-1.7 0-3 2-3 5s1.3 4 3 4 3-1 3-4-1.3-5-3-5Z" />
          <path d="M17 12v9" />
        </svg>
        <span class="font-hand text-lg leading-none">{label}</span>
      </span>
    </div>
  )
}
