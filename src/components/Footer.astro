---
import { site, emails, socials } from '../data/site';
const year = new Date().getFullYear();
const active = socials.filter((s) => s.href);
---

<footer class="border-t border-line bg-surface">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-10 sm:flex-row sm:items-center sm:justify-between sm:px-8"
  >
    <div>
      <p class="font-serif text-lg font-semibold text-ink">{site.brand}</p>
      <a
        href={`mailto:${emails.general}`}
        class="text-sm text-muted transition-colors hover:text-primary"
      >
        {emails.general}
      </a>
    </div>

    <div class="flex flex-wrap gap-x-5 gap-y-2">
      {
        active.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-muted transition-colors hover:text-primary"
          >
            {s.label}
          </a>
        ))
      }
      <a
        href="/rss.xml"
        class="text-sm font-medium text-muted transition-colors hover:text-primary"
      >
        RSS
      </a>
    </div>
  </div>
  <div class="mx-auto max-w-6xl px-5 pb-8 sm:px-8">
    <p class="text-xs text-muted">
      © {year} {site.name}. Made with love in {site.brand}.
    </p>
  </div>
</footer>
