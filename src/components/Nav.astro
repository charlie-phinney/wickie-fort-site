---
import { site } from '../data/site';
import { navItems, isVisible } from '../data/sections';
// The menu is generated from the sections that are visible (src/data/sections.ts),
// in Wickie's chosen order — so hiding or reordering a section updates the menu too.
---

<header
  class="sticky top-0 z-[30] border-b border-line/70 bg-bg/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3.5 sm:px-8"
    aria-label="Primary"
  >
    <a
      href="#top"
      class="group inline-flex items-baseline gap-1.5 font-serif text-lg font-semibold tracking-tight text-ink"
    >
      <span class="transition-colors group-hover:text-primary">{site.brand}</span>
      <span class="h-1.5 w-1.5 translate-y-[-1px] rounded-full bg-pop transition-transform duration-300 ease-out-expo group-hover:scale-125"></span>
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-8 md:flex">
      {
        navItems.map((item) =>
          item.id === 'shop' ? (
            <a
              href={item.href}
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary-deep transition-colors hover:text-primary"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                <path d="M3 6h18" />
                <path d="M16 10a4 4 0 0 1-8 0" />
              </svg>
              {item.label}
            </a>
          ) : (
            <a
              href={item.href}
              class="text-sm font-medium text-muted transition-colors hover:text-ink"
            >
              {item.label}
            </a>
          )
        )
      }
      {
        isVisible('work') && (
          <a
            href="#work"
            class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-bg shadow-soft transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:bg-primary-deep"
          >
            Work with me
          </a>
        )
      }
    </div>

    <!-- Mobile toggle (CSS-only via checkbox). sr-only, not `hidden`: a
         display:none checkbox can't take keyboard focus, which made the
         menu unopenable without a mouse. -->
    <input type="checkbox" id="nav-toggle" class="peer sr-only md:hidden" aria-label="Toggle menu" />
    <label
      for="nav-toggle"
      class="flex cursor-pointer items-center justify-center rounded-lg p-2 text-ink peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-primary md:hidden"
      aria-hidden="true"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </label>

    <!-- Mobile panel -->
    <div
      class="absolute inset-x-0 top-full hidden origin-top flex-col gap-1 border-b border-line bg-bg px-5 py-4 shadow-lift peer-checked:flex md:!hidden"
    >
      {
        navItems.map((item) =>
          item.id === 'shop' ? (
            <a
              href={item.href}
              class="flex items-center gap-2 rounded-lg px-3 py-2.5 text-base font-semibold text-primary-deep transition-colors hover:bg-surface"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                <path d="M3 6h18" />
                <path d="M16 10a4 4 0 0 1-8 0" />
              </svg>
              {item.label}
            </a>
          ) : (
            <a
              href={item.href}
              class="rounded-lg px-3 py-2.5 text-base font-medium text-ink transition-colors hover:bg-surface"
            >
              {item.label}
            </a>
          )
        )
      }
      {
        isVisible('work') && (
          <a
            href="#work"
            class="mt-1 rounded-full bg-ink px-4 py-2.5 text-center text-base font-semibold text-bg"
          >
            Work with me
          </a>
        )
      }
    </div>
  </nav>
</header>

<script>
  // Close the mobile menu after a link is tapped.
  const toggle = document.getElementById('nav-toggle') as HTMLInputElement | null;
  document.querySelectorAll('.peer-checked\\:flex a').forEach((link) => {
    link.addEventListener('click', () => {
      if (toggle) toggle.checked = false;
    });
  });
</script>
