---
import Media from './Media.astro';
import type { Recipe } from '../data/site';
interface Props {
  recipe: Recipe;
}
const { recipe } = Astro.props;
const Wrapper = recipe.href ? 'a' : 'div';
---

<Wrapper
  href={recipe.href}
  class="group flex flex-col overflow-hidden rounded-2xl border border-line bg-bg shadow-soft transition-all duration-500 ease-out-expo hover:-translate-y-1 hover:shadow-lift"
>
  <div class="overflow-hidden">
    <Media
      src={recipe.image}
      alt={recipe.title}
      label="Recipe photo"
      ratio="4/3"
      class="transition-transform duration-700 ease-out-expo group-hover:scale-105"
    />
  </div>
  <div class="flex flex-1 flex-col gap-2 p-5">
    {
      recipe.tag && (
        <span class="w-fit rounded-full bg-accent-soft px-2.5 py-1 text-xs font-semibold text-accent">
          {recipe.tag}
        </span>
      )
    }
    <h3 class="font-serif text-xl font-medium leading-snug text-ink">
      {recipe.title}
    </h3>
    <p class="text-sm leading-relaxed text-muted">{recipe.blurb}</p>
  </div>
</Wrapper>
