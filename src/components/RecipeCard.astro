---
import Media from './Media.astro';
import type { Recipe } from '../data/site';
interface Props {
  recipe: Recipe;
  featured?: boolean;
}
const { recipe, featured = false } = Astro.props;
const Wrapper = recipe.href ? 'a' : 'div';
---

<Wrapper
  href={recipe.href}
  class={`group relative flex flex-col overflow-hidden rounded-3xl border border-line bg-bg shadow-soft transition-all duration-500 ease-out-expo hover:-translate-y-1.5 hover:shadow-lift ${featured ? 'sm:col-span-2 sm:flex-row' : ''}`}
>
  <div class={`overflow-hidden ${featured ? 'sm:w-1/2' : ''}`}>
    <Media
      src={recipe.image}
      alt={recipe.title}
      label="Photo coming soon"
      ratio={featured ? '4/3' : '4/3'}
      class="h-full w-full transition-transform duration-700 ease-out-expo group-hover:scale-[1.04]"
    />
  </div>
  <div class={`flex flex-1 flex-col gap-2.5 p-6 ${featured ? 'sm:justify-center sm:p-9' : ''}`}>
    {
      recipe.tag && (
        <span class="w-fit rounded-full border border-primary/25 bg-primary-tint/60 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary-deep">
          {recipe.tag}
        </span>
      )
    }
    <h3 class={`font-serif font-medium leading-[1.08] text-ink ${featured ? 'text-2xl sm:text-3xl' : 'text-xl'}`}>
      {recipe.title}
    </h3>
    <p class={`leading-relaxed text-muted ${featured ? 'text-base' : 'text-sm'}`}>{recipe.blurb}</p>
    {
      recipe.href && (
        <span class="mt-1 inline-flex items-center gap-1.5 text-sm font-semibold text-primary-deep">
          Get the recipe
          <span class="transition-transform duration-300 ease-out-expo group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
        </span>
      )
    }
  </div>
</Wrapper>
