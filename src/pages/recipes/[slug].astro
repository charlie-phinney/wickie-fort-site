---
/*
  A single recipe's page. Built from the same content each card uses (see
  src/data/site.ts). Ingredients + method are optional: until Wickie writes
  them in /admin, the page shows a warm "coming soon" state instead of an
  empty shell, so every card leads somewhere that feels finished.
*/
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import Media from '../../components/Media.astro';
import { site, recipes, emails, linkTechniques } from '../../data/site';
import type { TextSegment } from '../../data/site';

export function getStaticPaths() {
  return recipes
    .filter((r) => r.slug)
    .map((r) => ({ params: { slug: r.slug! }, props: { recipe: r } }));
}

const { recipe } = Astro.props;
const hasMethod = recipe.ingredients.length > 0 || recipe.steps.length > 0;

// Technique mentions ("medium dice", "fabricate a chicken") become links to
// Wickie's how-to videos — computed at build time in src/data/site.ts, plain
// text again the moment no technique matches.
const linkedIngredients = linkTechniques(recipe.ingredients);
const linkedSteps = linkTechniques(recipe.steps);

// Group the method into sections: an optional "Prep your burger" heading plus
// its steps. Step numbering runs continuously across sections (the <ol start>
// below), which is what makes the numbers keep counting under each heading.
type StepSection = { heading?: string; start: number; steps: TextSegment[][] };
const stepSections: StepSection[] = [];
let stepCount = 0;
for (const part of linkedSteps) {
  if (part.kind === 'heading') {
    stepSections.push({ heading: part.text, start: stepCount + 1, steps: [] });
  } else {
    if (!stepSections.length) stepSections.push({ start: 1, steps: [] });
    stepSections[stepSections.length - 1].steps.push(part.segments);
    stepCount++;
  }
}

const ingredientItems = recipe.ingredients.filter((p) => p.kind === 'item').map((p) => p.text);
const stepItems = recipe.steps.filter((p) => p.kind === 'item').map((p) => p.text);

const instagram = 'https://www.instagram.com/wickieskitchen';
const askMailto = `mailto:${emails.general}?subject=${encodeURIComponent(
  `Recipe request: ${recipe.title}`
)}`;

const title = `${recipe.title} · ${site.brand}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Recipe structured data. Only the fields that actually exist are emitted, so
// the markup is always valid and automatically becomes a full rich-result
// candidate the moment Wickie adds a photo + ingredients + steps in /admin.
const recipeLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: recipe.title,
  description: recipe.blurb,
  url: canonical,
  author: { '@type': 'Person', name: 'Wickie Fort' },
};
if (recipe.image) recipeLd.image = new URL(recipe.image, Astro.site).href;
if (recipe.serves) recipeLd.recipeYield = recipe.serves;
if (ingredientItems.length) recipeLd.recipeIngredient = ingredientItems;
if (stepItems.length) {
  // With section headings, emit HowToSection groups; otherwise a flat step list.
  recipeLd.recipeInstructions = stepSections.some((s) => s.heading)
    ? stepSections.map((s) => ({
        '@type': 'HowToSection',
        ...(s.heading ? { name: s.heading } : {}),
        itemListElement: s.steps.map((text) => ({ '@type': 'HowToStep', text })),
      }))
    : stepItems.map((text) => ({ '@type': 'HowToStep', text }));
}

// Breadcrumb trail so search results can show Home › Recipes › <this recipe>.
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://wickiefort.com/' },
    { '@type': 'ListItem', position: 2, name: 'Recipes', item: 'https://wickiefort.com/#recipes' },
    { '@type': 'ListItem', position: 3, name: recipe.title, item: canonical },
  ],
};
---

<Base
  title={title}
  description={recipe.blurb}
  image={`/og/${recipe.slug}.png`}
  jsonLd={[recipeLd, breadcrumbLd]}
>
  <!-- Slim on-brand header (the homepage nav's in-page anchors don't apply on a
       sub-page, so this gives a clean way home + back to the recipe grid). -->
  <header class="no-print sticky top-0 z-[30] border-b border-line/70 bg-bg/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-5 py-3.5 sm:px-8">
      <a
        href="/"
        class="group inline-flex items-baseline gap-1.5 font-serif text-lg font-semibold tracking-tight text-ink"
      >
        <span class="transition-colors group-hover:text-primary">{site.brand}</span>
        <span class="h-1.5 w-1.5 translate-y-[-1px] rounded-full bg-pop transition-transform duration-300 ease-out-expo group-hover:scale-125"></span>
      </a>
      <a
        href="/#recipes"
        class="group inline-flex items-center gap-1.5 text-sm font-semibold text-muted transition-colors hover:text-ink"
      >
        <span class="transition-transform duration-300 ease-out-expo group-hover:-translate-x-1" aria-hidden="true">&larr;</span>
        All recipes
      </a>
    </div>
  </header>

  <main id="main">
    <article class="mx-auto max-w-4xl px-5 pb-20 pt-10 sm:px-8 md:pb-28 md:pt-14">
      <!-- Shown only on the printed page, so a print-out is attributable. -->
      <p class="print-brand hidden font-serif text-sm text-ink">
        {site.brand} · wickiefort.com
      </p>

      <!-- ------------------------------ header ------------------------------ -->
      <header class="max-w-prose">
        {
          recipe.tag && (
            <span class="inline-flex w-fit rounded-full border border-primary/25 bg-primary-tint/60 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary-deep">
              {recipe.tag}
            </span>
          )
        }
        <h1
          class={`font-serif font-semibold leading-[1.02] text-ink text-[clamp(2.3rem,6.5vw,3.6rem)] ${recipe.tag ? 'mt-4' : ''}`}
        >
          {recipe.title}
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-muted">{recipe.blurb}</p>

        {
          (recipe.serves || recipe.time) && (
            <dl class="mt-6 flex flex-wrap gap-x-8 gap-y-2 text-sm">
              {recipe.serves && (
                <div class="flex items-center gap-2">
                  <dt class="font-semibold uppercase tracking-wide text-primary-deep">Serves</dt>
                  <dd class="text-ink">{recipe.serves}</dd>
                </div>
              )}
              {recipe.time && (
                <div class="flex items-center gap-2">
                  <dt class="font-semibold uppercase tracking-wide text-primary-deep">Time</dt>
                  <dd class="text-ink">{recipe.time}</dd>
                </div>
              )}
            </dl>
          )
        }
      </header>

      <!-- Share (every recipe page is shareable) + Print (only once there's a
           written method worth printing). -->
      <div class="no-print mt-7 flex flex-wrap items-center gap-3">
        <button
          type="button"
          data-share
          data-url={canonical}
          data-title={recipe.title}
          data-text={recipe.blurb}
          class="inline-flex items-center gap-2 rounded-full border border-line bg-bg px-4 py-2 text-sm font-semibold text-ink transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:border-primary hover:text-primary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="18" cy="5" r="3" />
            <circle cx="6" cy="12" r="3" />
            <circle cx="18" cy="19" r="3" />
            <path d="m8.6 13.5 6.8 4M15.4 6.5l-6.8 4" />
          </svg>
          <span data-share-label>Share</span>
        </button>

        {
          hasMethod && (
            <button
              type="button"
              data-print
              class="inline-flex items-center gap-2 rounded-full border border-line bg-bg px-4 py-2 text-sm font-semibold text-ink transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:border-primary hover:text-primary"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 9V2h12v7" />
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                <path d="M6 14h12v8H6z" />
              </svg>
              Print recipe
            </button>
          )
        }

        {
          hasMethod && (
            /* Cook Mode: keeps the phone screen awake on the counter and bumps
               the method type up a size. Hidden by the script on browsers
               without the Wake Lock API, so it never shows a dead button. */
            <button
              type="button"
              data-cook
              aria-pressed="false"
              hidden
              class="inline-flex items-center gap-2 rounded-full border border-line bg-bg px-4 py-2 text-sm font-semibold text-ink transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:border-primary hover:text-primary aria-pressed:border-primary-deep aria-pressed:bg-primary-deep aria-pressed:text-bg"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2c1.8 2.2 3 3.9 3 5.7A3 3 0 0 1 9 8c0-1.9 1.2-3.8 3-6Z" />
                <path d="M4 12h16v3a6 6 0 0 1-6 6h-4a6 6 0 0 1-6-6v-3Z" />
                <path d="M20 13.5c1.4 0 2.5.9 2.5 2s-1.1 2-2.5 2" />
              </svg>
              <span data-cook-label>Cook Mode</span>
            </button>
          )
        }

        <span data-share-status role="status" aria-live="polite" class="sr-only" />
      </div>

      <!-- ------------------------------- photo ------------------------------ -->
      <!-- view-transition-name pairs with this recipe's card on the homepage,
           so the photo morphs between the two pages (CSS-only, global.css). -->
      <div
        class="recipe-photo mt-9 overflow-hidden rounded-[2rem] border-4 border-bg shadow-lift"
        style={`view-transition-name: r-${recipe.slug}`}
      >
        <Media src={recipe.image} alt={recipe.title} label="Photo coming soon" ratio="16/9" />
      </div>

      {
        hasMethod ? (
          <!-- ------------------- full recipe: ingredients + method ------------------- -->
          <div class="recipe-method mt-12 grid gap-10 md:mt-16 md:grid-cols-[0.8fr_1.2fr] md:gap-14">
            {recipe.ingredients.length > 0 && (
              <section aria-labelledby="ingredients-heading" class="md:sticky md:top-24 md:self-start">
                <h2 id="ingredients-heading" class="font-serif text-2xl font-semibold text-ink">
                  <span class="mark-underline">Ingredients</span>
                </h2>
                <ul class="mt-5 space-y-3">
                  {linkedIngredients.map((part, i) =>
                    part.kind === 'heading' ? (
                      <li class="list-none pt-3 first:pt-0 text-sm font-semibold uppercase tracking-wide text-primary-deep">
                        {part.text}
                      </li>
                    ) : (
                      /* Each ingredient is a real checkbox so shoppers/cooks can
                         tick things off. Checked state persists per recipe
                         (localStorage) so a page reload mid-cook loses nothing. */
                      <li class="text-[1.02rem] leading-snug text-ink">
                        <label class="group/ing flex cursor-pointer items-start gap-3">
                          <input
                            type="checkbox"
                            data-check={`ing-${i}`}
                            class="mt-1 h-4 w-4 flex-none cursor-pointer appearance-none rounded-full border-2 border-primary/60 transition-colors checked:border-primary checked:bg-primary"
                          />
                          <span class="transition-opacity group-has-[:checked]/ing:opacity-45 group-has-[:checked]/ing:line-through">
                            {part.segments.map((seg) =>
                              /* prettier-ignore — one line so no whitespace lands inside the underlined link */
                              seg.href ? <a href={seg.href} title={seg.title} class="howto-link">{seg.text}</a> : seg.text
                            )}
                          </span>
                        </label>
                      </li>
                    )
                  )}
                </ul>
              </section>
            )}

            {recipe.steps.length > 0 && (
              <section aria-labelledby="method-heading">
                <h2 id="method-heading" class="font-serif text-2xl font-semibold text-ink">
                  <span class="mark-underline">Method</span>
                </h2>
                {stepSections.map((sec) => (
                  <div class="mt-6 first-of-type:mt-6">
                    {sec.heading && (
                      <h3 class="mb-4 mt-8 font-serif text-xl font-semibold text-primary-deep">
                        {sec.heading}
                      </h3>
                    )}
                    <ol start={sec.start} class="space-y-6">
                      {sec.steps.map((step, i) => (
                        /* The number badge doubles as a done-toggle: tap it to
                           dim the step you've finished. aria-pressed carries
                           the state; persisted like the ingredient checks. */
                        <li class="group/step flex gap-4">
                          <button
                            type="button"
                            data-check={`step-${sec.start + i - 1}`}
                            aria-pressed="false"
                            aria-label={`Mark step ${sec.start + i} done`}
                            class="step-num flex h-8 w-8 flex-none cursor-pointer items-center justify-center rounded-full bg-primary-deep font-serif text-sm font-semibold text-bg transition-colors aria-pressed:bg-line aria-pressed:text-muted"
                          >
                            {sec.start + i}
                          </button>
                          <p class="step-text pt-0.5 text-lg leading-relaxed text-ink/90 transition-opacity group-has-[[aria-pressed='true']]/step:opacity-40">
                            {step.map((seg) =>
                              /* prettier-ignore — one line so no whitespace lands inside the underlined link */
                              seg.href ? <a href={seg.href} title={seg.title} class="howto-link">{seg.text}</a> : seg.text
                            )}
                          </p>
                        </li>
                      ))}
                    </ol>
                  </div>
                ))}
              </section>
            )}
          </div>
        ) : (
          <!-- ------------------------ graceful "coming soon" ------------------------ -->
          <section class="mt-12 md:mt-16">
            <div class="relative overflow-hidden rounded-3xl border border-line bg-surface px-6 py-12 text-center shadow-soft sm:px-10 sm:py-14">
              <div
                class="pointer-events-none absolute inset-0 opacity-70"
                style="background:radial-gradient(120% 80% at 82% 8%, oklch(0.86 0.09 60 / 0.6), transparent 58%), radial-gradient(120% 80% at 12% 96%, oklch(0.82 0.11 40 / 0.4), transparent 55%)"
                aria-hidden="true"
              />
              <div class="relative mx-auto max-w-md">
                <p class="font-hand text-3xl text-primary">Full recipe coming soon</p>
                <p class="mt-3 text-base leading-relaxed text-muted">
                  I'm writing up the ingredients and steps for this one. In the
                  meantime, you can watch me make it on Instagram, or ask me for
                  it directly and I'll send it your way.
                </p>
                <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
                  <a
                    href={instagram}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="rounded-full bg-primary-deep px-5 py-2.5 text-sm font-semibold text-bg shadow-soft transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:bg-primary hover:shadow-lift"
                  >
                    Watch on Instagram
                  </a>
                  <a
                    href={askMailto}
                    class="rounded-full border border-line bg-bg px-5 py-2.5 text-sm font-semibold text-ink transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:border-primary hover:text-primary"
                  >
                    Ask me for this recipe
                  </a>
                </div>
              </div>
            </div>
          </section>
        )
      }

      <!-- ------------------------------- footer nav ------------------------------- -->
      <div class="no-print mt-14 flex flex-wrap items-center justify-between gap-4 border-t border-line pt-8 md:mt-20">
        <a
          href="/#recipes"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-ink transition-colors hover:text-primary"
        >
          <span class="transition-transform duration-300 ease-out-expo group-hover:-translate-x-1" aria-hidden="true">&larr;</span>
          Back to all recipes
        </a>
        <a
          href={instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary-deep transition-colors hover:text-primary"
        >
          More on Instagram
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </article>
  </main>

  <Footer />
</Base>

<style is:global>
  /* Technique links: a recipe mentioning "medium dice" links to Wickie's
     how-to video (built in src/data/site.ts). Styled as a warm marker-ish
     underline so it reads as hers, not as a default blue link. */
  .howto-link {
    font-weight: 600;
    color: oklch(var(--primary-deep));
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, currentColor 45%, transparent);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }
  .howto-link:hover {
    text-decoration-color: currentColor;
  }

  /* Print-friendly recipe: drop the chrome and decoration, keep a clean
     ingredients + method card that reads well on paper. Only recipes with a
     written method expose the Print button, so this only ever runs on a page
     that has something worth printing. */
  @media print {
    .no-print,
    footer {
      display: none !important;
    }
    .print-brand {
      display: block !important;
      margin-bottom: 0.75rem;
    }
    /* the big decorative photo wastes ink and page height on paper */
    .recipe-photo {
      display: none !important;
    }
    /* single clean column instead of the screen's sticky two-column split */
    .recipe-method {
      display: block !important;
      margin-top: 1.5rem !important;
    }
    .recipe-method > section + section {
      margin-top: 1.75rem;
    }
    /* numbered step badges rely on a background fill that browsers drop when
       printing, so give them an ink outline to keep the numbers readable */
    .step-num {
      background: transparent !important;
      color: #000 !important;
      border: 1.5px solid #000;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }
    body {
      background: #fff !important;
    }
    * {
      box-shadow: none !important;
    }
    /* on paper a technique link is just words */
    .howto-link {
      text-decoration: none;
      color: inherit;
      font-weight: inherit;
    }
  }

  /* Cook Mode: method type steps up a size for a phone propped on the
     counter. Everything else about the mode lives in the script below. */
  html.cook-mode .step-text {
    font-size: 1.3rem;
    line-height: 1.65;
  }
</style>

<script>
  document
    .querySelector<HTMLButtonElement>('[data-print]')
    ?.addEventListener('click', () => window.print());

  // Share: use the native share sheet where available (mobile), otherwise
  // copy the link to the clipboard with a brief on-button confirmation.
  const shareBtn = document.querySelector<HTMLButtonElement>('[data-share]');
  if (shareBtn) {
    const label = shareBtn.querySelector<HTMLElement>('[data-share-label]');
    const status = document.querySelector<HTMLElement>('[data-share-status]');
    const url = shareBtn.dataset.url || window.location.href;
    const title = shareBtn.dataset.title || document.title;
    const text = shareBtn.dataset.text || '';
    const original = label?.textContent ?? 'Share';
    let timer: ReturnType<typeof setTimeout>;

    const flash = (msg: string) => {
      if (label) label.textContent = msg;
      if (status) status.textContent = msg;
      clearTimeout(timer);
      timer = setTimeout(() => {
        if (label) label.textContent = original;
        if (status) status.textContent = '';
      }, 2000);
    };

    shareBtn.addEventListener('click', async () => {
      if (navigator.share) {
        try {
          await navigator.share({ title, text, url });
          return;
        } catch (err) {
          // User dismissed the share sheet — do nothing. Any other error
          // falls through to the copy-link path below.
          if (err instanceof Error && err.name === 'AbortError') return;
        }
      }
      try {
        await navigator.clipboard.writeText(url);
        flash('Link copied!');
      } catch {
        flash('Press and hold to copy');
      }
    });
  }

  // ---- Tick-off state: ingredients + steps, persisted per recipe ----
  // Survives a mid-cook reload; expires after 12h so an old cook doesn't
  // greet the next visit pre-checked.
  const storeKey = `cook:${location.pathname}`;
  const loadDone = (): Set<string> => {
    try {
      const raw = localStorage.getItem(storeKey);
      if (!raw) return new Set();
      const saved = JSON.parse(raw) as { t: number; done: string[] };
      if (Date.now() - saved.t > 12 * 3600e3) {
        localStorage.removeItem(storeKey);
        return new Set();
      }
      return new Set(saved.done);
    } catch {
      return new Set();
    }
  };
  const doneSet = loadDone();
  const saveDone = () => {
    try {
      localStorage.setItem(storeKey, JSON.stringify({ t: Date.now(), done: [...doneSet] }));
    } catch {
      /* storage full/blocked — checks still work for the session */
    }
  };
  document.querySelectorAll<HTMLElement>('[data-check]').forEach((el) => {
    const id = el.dataset.check as string;
    const isBox = el instanceof HTMLInputElement;
    const apply = (on: boolean) => {
      if (isBox) (el as HTMLInputElement).checked = on;
      else el.setAttribute('aria-pressed', String(on));
    };
    if (doneSet.has(id)) apply(true);
    el.addEventListener(isBox ? 'change' : 'click', () => {
      const on = isBox
        ? (el as HTMLInputElement).checked
        : el.getAttribute('aria-pressed') !== 'true';
      apply(on);
      if (on) doneSet.add(id);
      else doneSet.delete(id);
      saveDone();
    });
  });

  // ---- Cook Mode: keep the screen awake while she cooks ----
  // The button stays hidden unless the Wake Lock API exists, so no browser
  // ever shows a button that does nothing.
  const cookBtn = document.querySelector<HTMLButtonElement>('[data-cook]');
  if (cookBtn && 'wakeLock' in navigator) {
    cookBtn.hidden = false;
    const cookLabel = cookBtn.querySelector<HTMLElement>('[data-cook-label]');
    let lock: { release(): Promise<void> } | null = null;
    let cooking = false;
    const acquire = async () => {
      try {
        lock = await (navigator as Navigator & {
          wakeLock: { request(type: 'screen'): Promise<{ release(): Promise<void> }> };
        }).wakeLock.request('screen');
      } catch {
        /* denied (e.g. low battery) — mode still zooms the type */
      }
    };
    cookBtn.addEventListener('click', async () => {
      cooking = !cooking;
      if (cooking) await acquire();
      else {
        await lock?.release().catch(() => {});
        lock = null;
      }
      cookBtn.setAttribute('aria-pressed', String(cooking));
      document.documentElement.classList.toggle('cook-mode', cooking);
      if (cookLabel) cookLabel.textContent = cooking ? 'Screen stays on' : 'Cook Mode';
    });
    // Browsers drop the lock when the tab hides; take it back on return.
    document.addEventListener('visibilitychange', () => {
      if (cooking && document.visibilityState === 'visible') acquire();
    });
  }
</script>
