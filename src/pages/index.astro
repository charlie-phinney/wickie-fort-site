---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Media from '../components/Media.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { site, emails, socials, about, recipes, workWithMe, shop, stats, reels } from '../data/site';
import { isVisible, orderIndex } from '../data/sections';

const activeSocials = socials.filter((s) => s.href);
const collabMailto = `mailto:${emails.general}?subject=${encodeURIComponent(
  "Partnership inquiry, Wickie's Kitchen"
)}`;
const helloMailto = `mailto:${emails.general}?subject=${encodeURIComponent(
  'Hello, Wickie!'
)}`;

// Order/visibility of the arrangeable sections (src/data/sections.ts). The
// hero is pinned first (order 0); everything else uses the CSS `order` Wickie
// set, and a hidden section simply isn't rendered.
const ord = (id: string) => `order:${orderIndex(id)}`;

// Millions formatter for the stats band ("28.8M+") — floored, never rounded
// up, because the views figure is stated as an honest floor. Mirrored
// client-side in the count-up script, so the two must stay in step.
const fmtM = (n: number) => `${(Math.floor(n / 1e5) / 10).toFixed(1).replace(/\.0$/, '')}M+`;

// Camera-roll strip: every photo already on the site, drifting slowly under
// the recipe grid. Purely decorative (aria-hidden) and self-maintaining —
// new photos Wickie uploads join the roll on the next deploy.
const cameraRoll = [
  ...new Set([site.heroImage, about.image, ...recipes.map((r) => r.image)].filter(Boolean)),
] as string[];

// Structured data: tells Google who Wickie is (a food creator) and links her
// verified profiles, so the site can surface as a proper knowledge entity.
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.brand,
    url: 'https://wickiefort.com/',
    inLanguage: 'en',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Wickie Fort',
    alternateName: site.brand,
    url: 'https://wickiefort.com/',
    jobTitle: 'Chef and food creator',
    description: site.heroSub,
    sameAs: activeSocials.map((s) => s.href),
  },
];
---

<Base
  title="Wickie's Kitchen · Simple, real food from a culinary school grad in New York"
  jsonLd={jsonLd}
>
  <span id="top" class="sr-only"></span>
  <Nav />

  <!-- Sections render top-to-bottom by their CSS `order` (see src/data/sections.ts),
       so Wickie can drag them into any order from /admin. Hero is always first. -->
  <main id="main" class="flex flex-col">
    <!-- ============================ HERO (pinned first) ============================ -->
    <section class="relative overflow-hidden" style="order:0">
      <!-- soft warm glow behind the type, top-left -->
      <div
        class="pointer-events-none absolute -left-40 -top-40 h-[34rem] w-[34rem] rounded-full opacity-60 blur-3xl"
        style="background:radial-gradient(circle, oklch(0.9 0.08 60 / 0.8), transparent 65%)"
        aria-hidden="true"
      >
      </div>

      <div
        class="relative mx-auto grid max-w-6xl items-center gap-10 px-5 pb-16 pt-12 sm:px-8 md:grid-cols-[1.05fr_0.95fr] md:gap-14 md:pb-24 md:pt-16"
      >
        <div data-reveal>
          <p class="font-hand text-2xl leading-none text-primary sm:text-[1.7rem]">
            {site.heroKicker}
          </p>
          <h1
            class="mt-4 font-serif text-[clamp(2.9rem,8.5vw,5.2rem)] font-semibold leading-[0.94] text-ink"
          >
            <span class="mark-underline">{site.tagline}</span>
          </h1>
          <p class="mt-6 max-w-[42ch] text-lg leading-relaxed text-muted">
            {site.heroSub}
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            {
              isVisible('work') && (
                <a
                  href="#work"
                  class="rounded-full bg-primary-deep px-6 py-3 text-base font-semibold text-bg shadow-soft transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:bg-primary hover:shadow-lift"
                >
                  Work with me
                </a>
              )
            }
            {
              isVisible('recipes') && (
                <a
                  href="#recipes"
                  class="rounded-full border border-line bg-bg px-6 py-3 text-base font-semibold text-ink transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:border-primary hover:text-primary"
                >
                  See my recipes
                </a>
              )
            }
          </div>
        </div>

        <!-- Hero portrait on an offset color backplate -->
        <div data-reveal class="relative mx-auto w-full max-w-sm md:max-w-none">
          <div
            class="absolute -bottom-4 -right-4 h-full w-full rounded-[2.2rem] bg-primary/90"
            aria-hidden="true"
          >
          </div>
          <div
            class="absolute -left-5 -top-5 h-24 w-24 rounded-full bg-pop shadow-soft md:h-28 md:w-28"
            aria-hidden="true"
          >
          </div>
          <div class="relative overflow-hidden rounded-[2.2rem] border-4 border-bg shadow-lift">
            <Media
              src={site.heroImage}
              label="Add your hero photo"
              alt="Wickie in the kitchen"
              ratio="4/5"
              loading="eager"
            />
          </div>
          <div
            class="absolute -bottom-5 left-5 rounded-2xl border border-line bg-bg px-4 py-2.5 shadow-lift"
          >
            <p class="font-serif text-base font-semibold text-ink">{site.brand}</p>
            <p class="text-xs text-muted">Home cooking, made in NYC</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== BY THE NUMBERS (social proof) ===================== -->
    <!-- Followers, YouTube lifetime views and TikTok likes auto-refresh daily
         (src/data/stats.json); the two video numbers are kept by hand in /admin.
         The big numbers count up on reveal, then keep ticking with Wickie's
         real measured growth (see the stats script below) — a zero/unfetched
         value simply hides its tile. -->
    {
      isVisible('stats') && (
        <section class="bg-primary-deep text-bg" style={ord('stats')}>
          <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8 md:py-20">
            <p data-reveal class="font-hand text-2xl text-pop">By the numbers</p>
            <dl data-reveal class="mt-6 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
              {stats.live.views.value > 0 && (
                <div>
                  <dt
                    class="font-serif text-[clamp(2.6rem,7vw,4rem)] font-semibold leading-none tabular-nums"
                    data-stat
                    data-value={stats.live.views.value}
                    data-perday={stats.live.views.perDay}
                    data-fmt="m"
                  >
                    {fmtM(stats.live.views.value)}
                  </dt>
                  <dd class="mt-2 text-sm leading-snug text-bg/75">video views</dd>
                </div>
              )}
              {stats.totalLikes > 0 && (
                <div>
                  <dt class="font-serif text-[clamp(2.6rem,7vw,4rem)] font-semibold leading-none tabular-nums">
                    {fmtM(stats.totalLikes)}
                  </dt>
                  <dd class="mt-2 text-sm leading-snug text-bg/75">likes</dd>
                </div>
              )}
              {stats.engagementRate && (
                <div>
                  <dt class="font-serif text-[clamp(2.6rem,7vw,4rem)] font-semibold leading-none tabular-nums">
                    {stats.engagementRate}%
                  </dt>
                  <dd class="mt-2 text-sm leading-snug text-bg/75">average engagement rate on Instagram</dd>
                </div>
              )}
              {stats.avgViews > 0 && (
                <div>
                  <dt class="font-serif text-[clamp(2.6rem,7vw,4rem)] font-semibold leading-none tabular-nums">
                    {stats.avgViews >= 1e6 ? fmtM(stats.avgViews) : `${Math.floor(stats.avgViews / 1e3)}K+`}
                  </dt>
                  <dd class="mt-2 text-sm leading-snug text-bg/75">average views per Instagram reel</dd>
                </div>
              )}
              {stats.videos1M > 0 && (
                <div>
                  <dt class="font-serif text-[clamp(2.6rem,7vw,4rem)] font-semibold leading-none tabular-nums">
                    {stats.videos1M}
                  </dt>
                  <dd class="mt-2 text-sm leading-snug text-bg/75">videos with over 1 million views</dd>
                </div>
              )}
              {stats.topVideoViews > 0 && (
                <div>
                  <dt class="font-serif text-[clamp(2.6rem,7vw,4rem)] font-semibold leading-none tabular-nums">
                    {fmtM(stats.topVideoViews)}
                  </dt>
                  <dd class="mt-2 text-sm leading-snug text-bg/75">views on my most-viewed video</dd>
                </div>
              )}
            </dl>
          </div>
        </section>
      )
    }

    <!-- ============================ ABOUT ============================ -->
    {
      isVisible('about') && (
        <section id="about" class="bg-surface" style={ord('about')}>
          <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 sm:px-8 md:grid-cols-[0.85fr_1.15fr] md:gap-16 md:py-24">
            <div data-reveal class="relative order-2 md:order-1">
              <div class="overflow-hidden rounded-[2rem] border-4 border-bg shadow-lift">
                <Media src={about.image} label="Add a photo of you" alt="Portrait of Wickie" ratio="4/5" />
              </div>
              <span class="absolute -right-3 -top-3 rotate-6 rounded-xl bg-pop px-3 py-1 font-hand text-xl text-ink shadow-soft">
                hi!
              </span>
            </div>
            <div data-reveal class="order-1 md:order-2">
              <h2 class="font-serif text-[clamp(2.1rem,5.5vw,3.2rem)] font-semibold text-ink">
                {about.heading}
              </h2>
              <div class="mt-6 space-y-4 text-lg leading-relaxed text-muted">
                {about.paragraphs.map((p) => <p>{p}</p>)}
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- ========================= WORK WITH ME ========================= -->
    {
      isVisible('work') && (
        <section id="work" class="bg-ink text-bg" style={ord('work')}>
          <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 md:py-24">
            <div class="grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:gap-16">
              <div data-reveal>
                <h2 class="font-serif text-[clamp(2.1rem,5.5vw,3.2rem)] font-semibold">
                  {workWithMe.heading}
                </h2>
                <p class="mt-6 max-w-prose text-lg leading-relaxed text-bg/85">
                  {workWithMe.intro}
                </p>
                <a
                  href={collabMailto}
                  class="mt-8 inline-flex rounded-full bg-pop px-6 py-3 text-base font-semibold text-ink shadow-soft transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:shadow-lift"
                >
                  {workWithMe.cta}
                </a>
              </div>

              <div data-reveal class="md:pt-2">
                <p class="font-hand text-2xl text-pop">Here's how we can team up</p>
                <ul class="mt-5 grid gap-x-8 gap-y-4 sm:grid-cols-2">
                  {workWithMe.offerings.map((item) => (
                    <li class="flex items-start gap-3">
                      <svg class="mt-0.5 h-5 w-5 flex-none text-pop" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M20 6 9 17l-5-5" />
                      </svg>
                      <span class="text-base leading-snug text-bg/90">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- ============================= SHOP ============================= -->
    {
      isVisible('shop') && (
        <section id="shop" class="mx-auto w-full max-w-6xl px-5 py-16 sm:px-8 md:py-24" style={ord('shop')}>
          <div data-reveal class="max-w-prose">
            <h2 class="font-serif text-[clamp(2.1rem,5.5vw,3.2rem)] font-semibold text-ink">
              {shop.heading}
            </h2>
            {shop.intro && <p class="mt-4 text-lg leading-relaxed text-muted">{shop.intro}</p>}
          </div>

          {
            shop.embedSrc ? (
              /* Wickie's ShopMy shop, embedded right on the page. The iframe
                 is built HERE from the extracted URL (never her raw paste —
                 see src/data/site.ts) and lazy-loaded: ShopMy pulls in a
                 whole React app, which shouldn't tax first paint. */
              <div data-reveal class="mt-10 overflow-hidden rounded-2xl">
                <iframe title="Shop my kitchen" src={shop.embedSrc} loading="lazy" />
              </div>
            ) : (
              shop.url && (
                <a
                  data-reveal
                  href={shop.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-8 inline-flex items-center gap-2 rounded-full bg-primary-deep px-6 py-3 text-base font-semibold text-bg shadow-soft transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:bg-primary hover:shadow-lift"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                    <path d="M3 6h18" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                  </svg>
                  Shop my kitchen
                </a>
              )
            )
          }
        </section>
      )
    }

    <!-- ======================= PHILOSOPHY BAND ======================= -->
    {
      isVisible('philosophy') && (
        <section class="bg-ink text-bg" style={ord('philosophy')}>
          <div class="mx-auto max-w-4xl px-5 py-16 text-center sm:px-8 md:py-24">
            <p data-reveal class="font-serif text-[clamp(1.7rem,4.2vw,2.7rem)] font-medium leading-[1.25]">
              Less is more, and simple is better. Good food comes from good
              ingredients and real technique, not from making things complicated
              for no reason.
            </p>
            <p data-reveal class="mt-6 font-hand text-3xl text-pop">Wickie</p>
          </div>
        </section>
      )
    }

    <!-- =========================== RECIPES =========================== -->
    {
      isVisible('recipes') && (
        <section id="recipes" class="mx-auto w-full max-w-6xl px-5 py-16 sm:px-8 md:py-24" style={ord('recipes')}>
          <div data-reveal class="flex flex-wrap items-end justify-between gap-4">
            <div class="max-w-prose">
              <h2 class="font-serif text-[clamp(2.1rem,5.5vw,3.2rem)] font-semibold text-ink">
                What I'm cooking
              </h2>
              <p class="mt-4 text-lg leading-relaxed text-muted">
                The simple, real food I make at home and come back to. New recipes
                added as I make (and remake) them.
              </p>
            </div>
            <a
              href={`https://www.instagram.com/wickieskitchen`}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden shrink-0 items-center gap-1.5 rounded-full border border-line px-5 py-2.5 text-sm font-semibold text-ink transition-all duration-300 ease-out-expo hover:border-primary hover:text-primary sm:inline-flex"
            >
              More on Instagram
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>

          <div data-reveal class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {recipes.map((recipe) => <RecipeCard recipe={recipe} />)}
          </div>

          {reels.length >= 3 && (
            /* Latest from Instagram — auto-refreshed daily (fetch-reels.mjs),
               so this row stays current forever without anyone touching it. */
            <div data-reveal class="mt-16">
              <p class="font-hand text-2xl text-primary">Fresh from my Instagram</p>
              <div class="-mx-5 mt-5 flex snap-x snap-mandatory gap-4 overflow-x-auto px-5 pb-3 sm:mx-0 sm:px-0 lg:grid lg:grid-cols-6 lg:overflow-visible lg:pb-0">
                {reels.map((reel) => (
                  <a
                    href={reel.permalink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group relative w-36 flex-none snap-start overflow-hidden rounded-2xl shadow-soft transition-all duration-500 ease-out-expo hover:-translate-y-1 hover:shadow-lift sm:w-40 lg:w-auto"
                  >
                    <img
                      src={reel.image}
                      alt={reel.caption || 'Instagram post from Wickie'}
                      loading="lazy"
                      decoding="async"
                      class="aspect-[9/16] w-full object-cover transition-transform duration-700 ease-out-expo group-hover:scale-[1.05]"
                    />
                    {reel.isVideo && (
                      <span
                        class="absolute right-2.5 top-2.5 flex h-7 w-7 items-center justify-center rounded-full bg-ink/55 text-bg backdrop-blur-sm"
                        aria-hidden="true"
                      >
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M7 4.5v15l13-7.5-13-7.5Z" />
                        </svg>
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </div>
          )}

          {cameraRoll.length >= 4 && (
            <div class="mt-14 overflow-hidden rounded-2xl py-3" aria-hidden="true">
              <div class="camera-roll flex w-max">
                {[0, 1].map(() => (
                  <div class="flex gap-4 pr-4">
                    {cameraRoll.map((src, i) => (
                      <img
                        src={src}
                        alt=""
                        loading="lazy"
                        decoding="async"
                        class={`h-36 w-52 flex-none rounded-xl object-cover shadow-soft md:h-44 md:w-64 ${
                          i % 2 ? 'rotate-[1.2deg]' : '-rotate-[1.2deg]'
                        }`}
                      />
                    ))}
                  </div>
                ))}
              </div>
            </div>
          )}
        </section>
      )
    }

    <!-- =========================== CONTACT =========================== -->
    {
      isVisible('contact') && (
        <section id="contact" class="mx-auto w-full max-w-6xl px-5 py-16 sm:px-8 md:py-24" style={ord('contact')}>
          <div data-reveal class="max-w-prose">
            <h2 class="font-serif text-[clamp(2.1rem,5.5vw,3.2rem)] font-semibold text-ink">
              Say hello
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-muted">
              Questions, kind notes, recipe requests, or just want to say hi? I'd
              genuinely love to hear from you.
            </p>
          </div>

          <a
            href={helloMailto}
            data-reveal
            class="group mt-10 flex flex-col gap-4 rounded-2xl border border-line bg-bg p-7 shadow-soft transition-all duration-300 ease-out-expo hover:-translate-y-1 hover:border-primary hover:shadow-lift sm:flex-row sm:items-center sm:justify-between sm:p-8"
          >
            <div>
              <span class="text-sm font-semibold text-primary-deep">Questions, kind notes, or brand partnerships</span>
              <span class="mt-1 block font-serif text-2xl text-ink sm:text-3xl">{emails.general}</span>
            </div>
            <span class="inline-flex w-fit shrink-0 items-center gap-2 rounded-full bg-primary-deep px-5 py-3 text-base font-semibold text-bg transition-all duration-300 ease-out-expo group-hover:bg-primary">
              Email me
              <span class="transition-transform duration-300 ease-out-expo group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
            </span>
          </a>

          {
            activeSocials.length > 0 && (
              <div data-reveal class="mt-10">
                <p class="font-hand text-2xl text-primary">Come follow along</p>
                <div class="mt-3 flex flex-wrap gap-3">
                  {activeSocials.map((s) => (
                    <a
                      href={s.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="rounded-full border border-line bg-bg px-4 py-2 text-sm font-semibold text-ink transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:border-primary hover:text-primary"
                    >
                      {s.label}
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </section>
      )
    }
  </main>

  <Footer />
</Base>

<style>
  /* The ShopMy embed Wickie pastes ships min-height:340px inline, but its
     shelf actually renders ~356px tall (more when product titles wrap), so
     the buy buttons got shaved off. !important because the pasted style is
     inline on the iframe; :global because set:html content isn't scoped. */
  #shop :global(iframe) {
    display: block;
    width: 100% !important;
    min-height: 400px !important;
  }

  /* Reveal-on-scroll: content is visible by default; JS opts in to the
     animation only when motion is allowed, so nothing ever ships blank. */
  @media (prefers-reduced-motion: no-preference) {
    :global([data-reveal].reveal-init) {
      opacity: 0;
      transform: translateY(18px);
    }
    :global([data-reveal].reveal-in) {
      opacity: 1;
      transform: none;
      transition:
        opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* The brand's motion signature, riding the same reveal opt-in (so no-JS
       and reduced-motion always see the finished state):
       - the marigold underline draws itself in like a marker stroke
       - handwritten accents wipe on left-to-right, like being written */
    :global([data-reveal].reveal-init .mark-underline) {
      background-size: 0% 0.14em;
    }
    :global([data-reveal].reveal-in .mark-underline) {
      background-size: 100% 0.14em;
      transition: background-size 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.35s;
    }
    :global([data-reveal].reveal-init .font-hand),
    :global([data-reveal].reveal-init.font-hand) {
      clip-path: inset(-20% 100% -20% 0);
    }
    :global([data-reveal].reveal-in .font-hand),
    :global([data-reveal].reveal-in.font-hand) {
      clip-path: inset(-20% -5% -20% 0);
      transition: clip-path 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.15s;
    }
  }

  /* Camera roll: two identical halves slide by exactly one half for a
     seamless loop. The global reduced-motion rules freeze it into a static
     (identical-looking) strip. */
  :global(.camera-roll) {
    animation: camera-roll 50s linear infinite;
  }
  @keyframes camera-roll {
    to {
      transform: translateX(-50%);
    }
  }
</style>

<script>
  // ---- Stats band: count up on reveal, then keep ticking with real growth ----
  // data-perday is Wickie's measured daily growth (computed in site.ts from the
  // stats history — zero until two days of history exist), extrapolated live so
  // the numbers visibly climb while you watch. Never a made-up rate.
  const fmtStat = (n: number, kind?: string) =>
    kind === 'm'
      ? `${(Math.floor(n / 1e5) / 10).toFixed(1).replace(/\.0$/, '')}M+`
      : kind === 'k'
        ? `${Math.floor(n / 1000)}K+`
        : String(Math.round(n));
  const reduceStats = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll<HTMLElement>('[data-stat]').forEach((el) => {
    const target = Number(el.dataset.value || 0);
    const perDay = Number(el.dataset.perday || 0);
    const kind = el.dataset.fmt;
    const t0 = Date.now();
    const now = () => target + (perDay * (Date.now() - t0)) / 86400e3;
    const render = (n: number) => {
      el.textContent = fmtStat(n, kind);
    };
    const startTicker = () => {
      if (perDay > 0) setInterval(() => render(now()), 4000);
    };
    if (reduceStats || !('IntersectionObserver' in window)) {
      startTicker();
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        if (!entries.some((e) => e.isIntersecting)) return;
        io.disconnect();
        const start = performance.now();
        const dur = 1200;
        const frame = (t: number) => {
          const p = Math.min(1, (t - start) / dur);
          render(target * (1 - Math.pow(1 - p, 4))); // ease-out-quart
          if (p < 1) requestAnimationFrame(frame);
          else startTicker();
        };
        requestAnimationFrame(frame);
      },
      { threshold: 0.4 }
    );
    io.observe(el);
  });

  // Progressive enhancement: only hide-then-reveal if JS runs and motion is OK.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const els = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
  const reveal = (el: HTMLElement) => {
    el.classList.add('reveal-in');
    el.classList.remove('reveal-init');
  };

  if (!reduce && 'IntersectionObserver' in window) {
    els.forEach((el) => el.classList.add('reveal-init'));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            reveal(entry.target as HTMLElement);
            io.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
    );
    els.forEach((el) => io.observe(el));

    // Failsafe: content must NEVER stay hidden if the observer can't fire
    // (background tabs, headless renderers, bfcache restores).
    const revealInView = () => {
      els.forEach((el) => {
        if (!el.classList.contains('reveal-init')) return;
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) reveal(el);
      });
    };
    window.addEventListener('load', () => setTimeout(revealInView, 600));
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) revealInView();
    });
    window.addEventListener('pageshow', (e) => {
      if (e.persisted) revealInView();
    });
  }
</script>
