---
/* ==================================================================== */
/*  MEDIA KIT — the brand-facing one-pager.                              */
/*  Every number is the same live, daily-measured data the homepage      */
/*  band uses; nothing here is hand-maintained. Prints clean (the page   */
/*  is built on the light canvas; nav/footer/buttons hide in print), so  */
/*  "save as PDF" from the browser is the PDF version.                   */
/* ==================================================================== */
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site, emails, about, workWithMe, stats } from '../data/site';
import { fmtM, fmtCount } from '../data/format';

const igAvatar = stats.platforms.find((p) => p.name === 'Instagram')?.profile?.avatar;
const recentWork = stats.platforms
  .flatMap((p) => (p.profile?.recent || []).map((r) => ({ ...r, platform: p.name })))
  .slice(0, 9);
---

<Base
  title={`Media kit · ${site.brand}`}
  description={`Work with ${site.name}: audience and reach for ${site.brand}, measured daily.`}
>
  <div class="print:hidden">
    <Nav />
  </div>

  <main class="mx-auto max-w-4xl px-5 py-12 sm:px-8 md:py-16">
    <!-- Header: who this is -->
    <header class="flex flex-wrap items-center gap-5">
      {
        igAvatar && (
          <img
            src={igAvatar}
            alt={`${site.name}`}
            width="176"
            height="176"
            class="h-20 w-20 rounded-full border-4 border-surface object-cover shadow-soft"
          />
        )
      }
      <div class="min-w-0">
        <p class="font-hand text-2xl text-primary-deep">Media kit</p>
        <h1 class="font-serif text-[clamp(2rem,6vw,3rem)] font-semibold leading-tight text-ink">
          {site.name} · {site.brand}
        </h1>
        <p class="mt-1 text-muted">{site.tagline}</p>
      </div>
    </header>

    <!-- Headline numbers (same live data as the homepage band) -->
    <section class="mt-12 flex flex-wrap items-end gap-x-14 gap-y-8">
      <div>
        <p class="font-serif text-[clamp(3rem,8vw,4.5rem)] font-semibold leading-none tabular-nums text-ink">
          {fmtM(stats.live.views.value)}
        </p>
        <p class="mt-3 text-base text-muted">total views</p>
      </div>
      <div>
        <p class="font-serif text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold leading-none tabular-nums text-ink">
          {fmtCount(stats.followersShown)}
        </p>
        <p class="mt-3 text-base text-muted">followers</p>
      </div>
      <div>
        <p class="font-serif text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold leading-none tabular-nums text-ink">
          {stats.videos1M}
        </p>
        <p class="mt-3 text-base text-muted">videos past a million views</p>
      </div>
      {
        stats.countries > 0 && (
          <div>
            <p class="font-serif text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold leading-none tabular-nums text-ink">
              {stats.countries}
            </p>
            <p class="mt-3 text-base text-muted">countries follow along</p>
          </div>
        )
      }
    </section>

    <!-- Per-platform table -->
    <table class="mt-12 w-full border-collapse text-left">
      <thead>
        <tr class="text-sm text-muted">
          <th scope="col" class="pb-3 font-normal"></th>
          <th scope="col" class="pb-3 text-right font-normal">Views</th>
          <th scope="col" class="pb-3 text-right font-normal">Followers</th>
          <th scope="col" class="pb-3 text-right font-normal">
            <span class="sm:hidden">1M+</span>
            <span class="hidden sm:inline">Videos past 1M</span>
          </th>
        </tr>
      </thead>
      <tbody>
        {
          stats.platforms.map((p) => (
            <tr class="border-t border-line">
              <th scope="row" class="py-4 pr-4 font-serif text-lg font-semibold text-ink sm:text-xl">
                {p.profile ? (
                  <a href={p.profile.href} target="_blank" rel="noopener" class="hover:text-primary">
                    {p.name}
                    <span class="ml-2 hidden text-sm font-normal text-muted sm:inline">{p.profile.handle}</span>
                  </a>
                ) : (
                  p.name
                )}
              </th>
              <td class="py-4 text-right font-serif text-2xl font-semibold tabular-nums text-ink sm:text-3xl">
                {fmtCount(p.views)}
              </td>
              <td class="py-4 text-right font-serif text-2xl font-semibold tabular-nums text-ink sm:text-3xl">
                {fmtCount(p.followers)}
              </td>
              <td class="py-4 text-right font-serif text-2xl font-semibold tabular-nums text-ink sm:text-3xl">
                {p.over1M > 0 ? p.over1M : ''}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>

    <!-- What working together looks like -->
    <section class="mt-12 grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:gap-14">
      <div>
        <h2 class="font-serif text-2xl font-semibold text-ink">{workWithMe.heading}</h2>
        <p class="mt-4 max-w-prose leading-relaxed text-muted">{workWithMe.intro}</p>
        {
          workWithMe.offerings.length > 0 && (
            <ul class="mt-5 space-y-2 text-ink">
              {workWithMe.offerings.map((o) => (
                <li class="flex items-baseline gap-3">
                  <span class="h-1.5 w-1.5 shrink-0 translate-y-[-2px] rounded-full bg-pop" />
                  {o}
                </li>
              ))}
            </ul>
          )
        }
        <div class="mt-8 flex flex-wrap gap-3 print:hidden">
          <a
            href={`mailto:${emails.general}`}
            class="rounded-full bg-primary-deep px-6 py-3 text-base font-semibold text-bg shadow-soft transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:bg-primary hover:shadow-lift"
          >
            {workWithMe.cta}
          </a>
          <a
            href="/media-kit.pdf"
            download="wickies-kitchen-media-kit.pdf"
            class="rounded-full border-2 border-line px-6 py-3 text-base font-semibold text-ink transition-all duration-300 ease-out-expo hover:-translate-y-0.5 hover:border-primary hover:text-primary"
          >
            Download PDF
          </a>
        </div>
        <p class="mt-4 hidden text-ink print:block">{emails.general}</p>
      </div>
      {
        about.image && (
          <div class="overflow-hidden rounded-[2rem] border-4 border-surface shadow-lift print:hidden">
            <img src={about.image} alt={`Portrait of ${site.name}`} loading="lazy" class="h-full w-full object-cover" />
          </div>
        )
      }
    </section>

    <!-- Recent work -->
    {
      recentWork.length >= 6 && (
        <section class="mt-12 print:hidden">
          <h2 class="font-serif text-2xl font-semibold text-ink">Recent videos</h2>
          <div class="mt-5 grid grid-cols-3 gap-2 sm:grid-cols-9 sm:gap-3">
            {recentWork.map((r) => (
              <a href={r.url} target="_blank" rel="noopener" aria-label={`Recent ${r.platform} video`}>
                <img
                  src={r.image}
                  alt=""
                  loading="lazy"
                  width="270"
                  height="480"
                  class="aspect-[9/16] w-full rounded-lg object-cover transition-transform duration-300 ease-out-expo hover:scale-[1.04]"
                />
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>

  <div class="print:hidden">
    <Footer />
  </div>
</Base>
