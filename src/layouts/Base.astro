---
import fs from 'node:fs';
import '../styles/global.css';
import { site } from '../data/site';
import { theme } from '../data/theme';
import { googleCssUrl } from '../data/font-pairings.mjs';

interface Props {
  title?: string;
  description?: string;
  image?: string; // social-share image path, relative to the site root
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]; // schema.org structured data
  noindex?: boolean; // error pages: keep them out of search results
}

const {
  title = `${site.name} · ${site.brand}`,
  description = site.heroSub,
  image = '/og.png',
  jsonLd,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const favicon = `${base}/favicon.svg`;
const ogImage = new URL(image, Astro.site).href;

// "Look & Feel" theme (src/data/theme.ts): Wickie's chosen palette, font
// pairing, and text size. Applied as inline custom properties on <html> so
// they always win over the global.css defaults, and the matching font files
// are loaded below. This is what lets her re-skin the whole site safely.
const themeVars = [
  ...Object.entries(theme.colors).map(([role, value]) => `--${role}:${value}`),
  `--font-serif:${theme.fonts.serif}`,
  `--font-sans:${theme.fonts.sans}`,
  // --font-hand is NOT overridden here: Caveat is the site's constant
  // signature (loaded below), and pairings don't define a `hand` stack —
  // emitting one printed the literal string "undefined", which knocked every
  // handwritten accent back to the browser's default font.
  `font-size:${theme.rootPercent}%`,
].join(';');
// Fonts are self-hosted: scripts/vendor-fonts.mjs mirrors the active
// pairing's files into public/fonts/ (committed, refreshed by CI), and the
// small @font-face stylesheet is inlined below — no render-blocking
// third-party CSS, no fonts.gstatic.com connection. Until the vendored
// files exist for a new pairing, the Google links keep everything working.
const vendoredCss = fs.existsSync('public/fonts/fonts.css')
  ? fs.readFileSync('public/fonts/fonts.css', 'utf8')
  : '';
// Vendored for the active pairing? (A pairing switch in /admin deploys
// before CI's housekeeping commit lands the new files — fall back to the
// CDN for that one build instead of showing system fonts.)
const primaryFamily = /'([^']+)'/.exec(theme.fonts.serif)?.[1] || '';
const vendoredFresh = vendoredCss.includes(`font-family: '${primaryFamily}'`);
const fontsHref = googleCssUrl(theme.fonts);
---

<!doctype html>
<html lang="en" style={themeVars}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/site.webmanifest`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.brand} · Recipes`}
      href={`${base}/rss.xml`}
    />
    <meta name="theme-color" content="#c05a3c" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.brand}. ${site.tagline}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: display serif + body sans (Wickie's pairing) + Caveat (hand
         accent). Self-hosted from /fonts (vendor-fonts.mjs); the @font-face
         rules are inlined so nothing render-blocking leaves this origin. -->
    {
      vendoredFresh ? (
        <style set:html={vendoredCss} />
      ) : (
        <>
          <link rel="preconnect" href="https://fonts.googleapis.com" />
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
          <link rel="stylesheet" href={fontsHref} />
        </>
      )
    }

    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6176628379786252"
      crossorigin="anonymous"
    />

    <!-- GoatCounter: privacy-friendly page counts (no cookies, no consent
         banner needed). count.js is self-hosted (public/js/count.js, vendored
         from gc.zgo.at) and ignores localhost by itself, so dev stays clean.
         Dashboard: https://wickieskitchen.goatcounter.com -->
    <script
      is:inline
      data-goatcounter="https://wickieskitchen.goatcounter.com/count"
      async
      src="/js/count.js"
    />

    {
      /* JSON.stringify alone does NOT escape "</script>" — a CMS string
         containing it would break out of this tag and run as HTML (the same
         threat the shop-embed extractor guards). < keeps the JSON valid
         while making breakout impossible. */
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')}
        />
      )
    }
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-bg"
    >
      Skip to content
    </a>
    <slot />
    <script is:inline>
      // Smooth scrolling arms on the first interaction only; reload
      // scroll-restoration happens before any interaction, so it snaps
      // instantly instead of visibly gliding (the "creep" on hard reload).
      (function () {
        var arm = function () {
          document.documentElement.classList.add('smooth');
          ['pointerdown', 'keydown', 'touchstart'].forEach(function (t) {
            removeEventListener(t, arm);
          });
        };
        ['pointerdown', 'keydown', 'touchstart'].forEach(function (t) {
          addEventListener(t, arm, { passive: true });
        });
      })();
    </script>
  </body>
</html>
