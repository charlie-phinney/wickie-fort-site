---
import '../styles/global.css';
import { site } from '../data/site';
import { theme } from '../data/theme';

interface Props {
  title?: string;
  description?: string;
  image?: string; // social-share image path, relative to the site root
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]; // schema.org structured data
}

const {
  title = `${site.name} · ${site.brand}`,
  description = site.heroSub,
  image = '/og.png',
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const favicon = `${base}/favicon.svg`;
const ogImage = new URL(image, Astro.site).href;

// "Look & Feel" theme (src/data/theme.ts): Wickie's chosen palette, font
// pairing, and text size. Applied as inline custom properties on <html> so
// they always win over the global.css defaults, and the matching font files
// are loaded below. This is what lets her re-skin the whole site safely.
const themeVars = [
  ...Object.entries(theme.colors).map(([role, value]) => `--${role}:${value}`),
  `--font-serif:${theme.fonts.serif}`,
  `--font-sans:${theme.fonts.sans}`,
  `--font-hand:${theme.fonts.hand}`,
  `font-size:${theme.rootPercent}%`,
].join(';');
const fontsHref = `https://fonts.googleapis.com/css2?${theme.fonts.googleFamilies
  .map((f) => `family=${f}`)
  .join('&')}&family=Caveat:wght@600;700&display=swap`;
---

<!doctype html>
<html lang="en" style={themeVars}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/site.webmanifest`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.brand} — Recipes`}
      href={`${base}/rss.xml`}
    />
    <meta name="theme-color" content="#c05a3c" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.brand}. ${site.tagline}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: Fraunces (display serif) + Inter (body) + Caveat (hand accent). Free via Google Fonts. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsHref} />

    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-bg"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
